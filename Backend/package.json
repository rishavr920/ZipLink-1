{
  "name": "ziplink-backend",
  "version": "1.0.0",
  "description": "High-performance Distributed URL Shortener",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration"
  },
  "keywords": [
    "url-shortener",
    "distributed-systems",
    "redis"
  ],
  "author": "Rishav Raj",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^6.0.0",
    "ioredis": "^5.0.0",
    "joi": "^17.11.0",
    "mongoose": "^6.3.0",
    "qrcode": "^1.5.0",
    "rate-limit-redis": "^3.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "node-mocks-http": "^1.14.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
